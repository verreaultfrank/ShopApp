<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             xmlns:vm="clr-namespace:JobHunterDashboard.ViewModels"
             x:Class="JobHunterDashboard.Views.AnalyticsPage"
             Title="Analytics"
             BackgroundColor="{DynamicResource AppBackgroundColor}">

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!-- ═══════ TAB BAR ═══════ -->
        <Border Grid.Row="0" 
                BackgroundColor="{DynamicResource AppSurfaceColor}"
                Stroke="{DynamicResource AppBorderColor}"
                StrokeThickness="0,0,0,1"
                Padding="20,10">
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <Button Text="📊 Statistics"
                        Command="{Binding SelectTabCommand}" CommandParameter="0"
                        FontSize="14" FontAttributes="Bold" Padding="18,10" CornerRadius="8"
                        BackgroundColor="{DynamicResource AppPrimaryColor}"
                        TextColor="White"
                        x:Name="TabStatistics"/>
                <Button Text="📈 Regression"
                        Command="{Binding SelectTabCommand}" CommandParameter="1"
                        FontSize="14" Padding="18,10" CornerRadius="8"
                        BackgroundColor="{DynamicResource AppBorderColor}"
                        TextColor="{DynamicResource AppTextColor}"
                        x:Name="TabRegression"/>
                <Button Text="🤖 Machine Learning"
                        Command="{Binding SelectTabCommand}" CommandParameter="2"
                        FontSize="14" Padding="18,10" CornerRadius="8"
                        BackgroundColor="{DynamicResource AppBorderColor}"
                        TextColor="{DynamicResource AppTextColor}"
                        x:Name="TabML"/>
            </HorizontalStackLayout>
        </Border>

        <!-- ═══════ CONTENT AREA ═══════ -->
        <Grid Grid.Row="1">

            <!-- ─── STATISTICS TAB ─── -->
            <ScrollView IsVisible="{Binding IsStatisticsVisible}">
                <VerticalStackLayout Spacing="16" Padding="24,16">

                    <!-- Header row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="📊 Statistics Dashboard"
                               FontSize="26" FontAttributes="Bold"
                               TextColor="{DynamicResource AppPrimaryColor}"
                               VerticalOptions="Center"/>
                        <Button Grid.Column="1"
                                Text="{Binding IsConfigOpen, StringFormat='{0:Configuration ▲|Configuration ▼}'}"
                                Command="{Binding ToggleConfigCommand}"
                                FontSize="13" Padding="14,8" CornerRadius="8"
                                BackgroundColor="{DynamicResource AppBorderColor}"
                                TextColor="{DynamicResource AppTextColor}"
                                x:Name="BtnToggleConfig"/>
                    </Grid>

                    <!-- ─── CONFIGURATION PANEL ─── -->
                    <Border IsVisible="{Binding IsConfigOpen}"
                            BackgroundColor="{DynamicResource AppSurfaceColor}"
                            Stroke="{DynamicResource AppBorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="20">
                        <VerticalStackLayout Spacing="14">

                            <Label Text="Query Configuration" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource AppTextColor}"/>
                            <BoxView HeightRequest="1" Color="{DynamicResource AppBorderColor}"/>

                            <!-- Row 1: Primary Table & Join Table -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Primary Table" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppSubtextColor}"/>
                                    <Picker ItemsSource="{Binding Tables}"
                                            SelectedItem="{Binding SelectedPrimaryTable}"
                                            Title="Select table..."
                                            TextColor="{DynamicResource AppTextColor}"
                                            BackgroundColor="{DynamicResource AppSurfaceColor}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Join Table (optional)" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppSubtextColor}"/>
                                    <Picker ItemsSource="{Binding Tables}"
                                            SelectedItem="{Binding SelectedJoinTable}"
                                            Title="(None)"
                                            TextColor="{DynamicResource AppTextColor}"
                                            BackgroundColor="{DynamicResource AppSurfaceColor}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Row 2: Join details (visible only when join table selected) -->
                            <Grid IsVisible="{Binding IsJoinConfigVisible}" 
                                  ColumnDefinitions="*,*,*" ColumnSpacing="16">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Join Type" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppSubtextColor}"/>
                                    <Picker ItemsSource="{Binding JoinTypes}"
                                            SelectedItem="{Binding SelectedJoinType}"
                                            TextColor="{DynamicResource AppTextColor}"
                                            BackgroundColor="{DynamicResource AppSurfaceColor}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Left Join Column" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppSubtextColor}"/>
                                    <Picker ItemsSource="{Binding PrimaryColumns}"
                                            SelectedItem="{Binding JoinColumnLeft}"
                                            Title="Select column..."
                                            TextColor="{DynamicResource AppTextColor}"
                                            BackgroundColor="{DynamicResource AppSurfaceColor}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Spacing="4">
                                    <Label Text="Right Join Column" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppSubtextColor}"/>
                                    <Picker ItemsSource="{Binding JoinColumns}"
                                            SelectedItem="{Binding JoinColumnRight}"
                                            Title="Select column..."
                                            TextColor="{DynamicResource AppTextColor}"
                                            BackgroundColor="{DynamicResource AppSurfaceColor}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{DynamicResource AppBorderColor}"/>

                            <!-- Row 3: X/Y Axis, Aggregate, Chart Type -->
                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="X-Axis Column" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppSubtextColor}"/>
                                    <Picker ItemsSource="{Binding AllAvailableColumns}"
                                            SelectedItem="{Binding SelectedXAxis}"
                                            Title="Select..."
                                            TextColor="{DynamicResource AppTextColor}"
                                            BackgroundColor="{DynamicResource AppSurfaceColor}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Y-Axis Column" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppSubtextColor}"/>
                                    <Picker ItemsSource="{Binding AllAvailableColumns}"
                                            SelectedItem="{Binding SelectedYAxis}"
                                            Title="Select..."
                                            TextColor="{DynamicResource AppTextColor}"
                                            BackgroundColor="{DynamicResource AppSurfaceColor}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" Spacing="4">
                                    <Label Text="Aggregate" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppSubtextColor}"/>
                                    <Picker ItemsSource="{Binding AggregateFunctions}"
                                            SelectedItem="{Binding SelectedAggregate}"
                                            TextColor="{DynamicResource AppTextColor}"
                                            BackgroundColor="{DynamicResource AppSurfaceColor}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="3" Spacing="4">
                                    <Label Text="Chart Type" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource AppSubtextColor}"/>
                                    <Picker ItemsSource="{Binding ChartTypes}"
                                            SelectedItem="{Binding SelectedChartType}"
                                            TextColor="{DynamicResource AppTextColor}"
                                            BackgroundColor="{DynamicResource AppSurfaceColor}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Generate Button -->
                            <Button Text="⚡ Generate Chart"
                                    Command="{Binding RunQueryCommand}"
                                    FontSize="15" FontAttributes="Bold"
                                    Padding="20,12" CornerRadius="8"
                                    BackgroundColor="{DynamicResource AppPrimaryColor}"
                                    TextColor="White"
                                    HorizontalOptions="End"
                                    Margin="0,6,0,0"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Loading indicator -->
                    <ActivityIndicator IsVisible="{Binding IsLoading}" IsRunning="{Binding IsLoading}" 
                                       Color="{DynamicResource AppPrimaryColor}" HeightRequest="40"/>

                    <!-- Error message -->
                    <Border IsVisible="{Binding HasError}"
                            BackgroundColor="#FEE2E2" Stroke="#EF4444" StrokeThickness="1"
                            StrokeShape="RoundRectangle 8" Padding="14,10">
                        <Label Text="{Binding ErrorMessage}" TextColor="#DC2626" FontSize="13"/>
                    </Border>

                    <!-- ─── CHART AREA ─── -->
                    <!-- Cartesian Chart (Bar, Column, Line, Scatter) -->
                    <Border IsVisible="{Binding IsCartesianChart}"
                            BackgroundColor="{DynamicResource AppSurfaceColor}"
                            Stroke="{DynamicResource AppBorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="16"
                            MinimumHeightRequest="420">
                        <chart:SfCartesianChart x:Name="CartesianChart"
                                                HeightRequest="400">
                            <chart:SfCartesianChart.Title>
                                <Label Text="Query Results" FontSize="16" FontAttributes="Bold" 
                                       TextColor="{DynamicResource AppTextColor}" HorizontalOptions="Center"/>
                            </chart:SfCartesianChart.Title>

                            <chart:SfCartesianChart.XAxes>
                                <chart:CategoryAxis LabelStyle="{x:Null}">
                                    <chart:CategoryAxis.LabelStyle>
                                        <chart:ChartAxisLabelStyle TextColor="{DynamicResource AppSubtextColor}" FontSize="11"/>
                                    </chart:CategoryAxis.LabelStyle>
                                </chart:CategoryAxis>
                            </chart:SfCartesianChart.XAxes>

                            <chart:SfCartesianChart.YAxes>
                                <chart:NumericalAxis>
                                    <chart:NumericalAxis.LabelStyle>
                                        <chart:ChartAxisLabelStyle TextColor="{DynamicResource AppSubtextColor}" FontSize="11"/>
                                    </chart:NumericalAxis.LabelStyle>
                                </chart:NumericalAxis>
                            </chart:SfCartesianChart.YAxes>

                            <!-- Default series — will be swapped in code-behind based on chart type -->
                            <chart:ColumnSeries ItemsSource="{Binding ChartData}"
                                                XBindingPath="XValue"
                                                YBindingPath="YValue"
                                                Fill="{DynamicResource AppPrimaryColor}"
                                                x:Name="CartesianSeries"/>
                        </chart:SfCartesianChart>
                    </Border>

                    <!-- Circular Chart (Pie, Doughnut) -->
                    <Border IsVisible="{Binding IsCircularChart}"
                            BackgroundColor="{DynamicResource AppSurfaceColor}"
                            Stroke="{DynamicResource AppBorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="16"
                            MinimumHeightRequest="420">
                        <chart:SfCircularChart x:Name="CircularChart"
                                               HeightRequest="400">
                            <chart:SfCircularChart.Title>
                                <Label Text="Query Results" FontSize="16" FontAttributes="Bold"
                                       TextColor="{DynamicResource AppTextColor}" HorizontalOptions="Center"/>
                            </chart:SfCircularChart.Title>

                            <chart:PieSeries ItemsSource="{Binding ChartData}"
                                             XBindingPath="XValue"
                                             YBindingPath="YValue"
                                             x:Name="CircularSeries"/>
                        </chart:SfCircularChart>
                    </Border>

                    <!-- No data placeholder -->
                    <Border IsVisible="{Binding HasData, Converter={x:StaticResource InverseBoolConverter}}"
                            BackgroundColor="{DynamicResource AppSurfaceColor}"
                            Stroke="{DynamicResource AppBorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="40"
                            MinimumHeightRequest="200"
                            IsEnabled="{Binding IsLoading, Converter={x:StaticResource InverseBoolConverter}}">
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="📊" FontSize="48" HorizontalOptions="Center"/>
                            <Label Text="Configure your query above and click Generate Chart"
                                   FontSize="14" TextColor="{DynamicResource AppSubtextColor}" 
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ─── REGRESSION TAB (Placeholder) ─── -->
            <ScrollView IsVisible="{Binding IsRegressionVisible}">
                <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="📈" FontSize="64" HorizontalOptions="Center"/>
                    <Label Text="Regression Analysis"
                           FontSize="28" FontAttributes="Bold"
                           TextColor="{DynamicResource AppPrimaryColor}"
                           HorizontalOptions="Center"/>
                    <Border BackgroundColor="{DynamicResource AppSurfaceColor}"
                            Stroke="{DynamicResource AppBorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="30" MinimumWidthRequest="400">
                        <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                            <Label Text="🚧 Coming Soon" FontSize="20" FontAttributes="Bold" 
                                   TextColor="{DynamicResource AppTextColor}" HorizontalOptions="Center"/>
                            <Label Text="Linear and polynomial regression will be available here. Configure data sources, fit models, and visualize trend lines with prediction intervals."
                                   FontSize="14" TextColor="{DynamicResource AppSubtextColor}" 
                                   HorizontalTextAlignment="Center" MaximumWidthRequest="350"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <!-- ─── MACHINE LEARNING TAB (Placeholder) ─── -->
            <ScrollView IsVisible="{Binding IsMLVisible}">
                <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="🤖" FontSize="64" HorizontalOptions="Center"/>
                    <Label Text="Machine Learning"
                           FontSize="28" FontAttributes="Bold"
                           TextColor="{DynamicResource AppPrimaryColor}"
                           HorizontalOptions="Center"/>
                    <Border BackgroundColor="{DynamicResource AppSurfaceColor}"
                            Stroke="{DynamicResource AppBorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="30" MinimumWidthRequest="400">
                        <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                            <Label Text="🚧 Coming Soon" FontSize="20" FontAttributes="Bold" 
                                   TextColor="{DynamicResource AppTextColor}" HorizontalOptions="Center"/>
                            <Label Text="Classification, clustering, and anomaly detection models will be available here. Train ML.NET models directly from your data and visualize predictions."
                                   FontSize="14" TextColor="{DynamicResource AppSubtextColor}" 
                                   HorizontalTextAlignment="Center" MaximumWidthRequest="350"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>
</ContentPage>
