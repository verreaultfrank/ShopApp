<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:JobHunterDashboard.ViewModels"
             x:Class="JobHunterDashboard.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="{DynamicResource AppBackgroundColor}">

    <ScrollView>
        <VerticalStackLayout Padding="30,20,30,20" Spacing="20">
            
            <Label Text="Application Settings" 
                   SemanticProperties.HeadingLevel="Level1"
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="{DynamicResource AppPrimaryColor}"/>
            
            <Border BackgroundColor="{DynamicResource AppSurfaceColor}" 
                    Stroke="{DynamicResource AppBorderColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="20"
                    Margin="0,10,0,0">
                <VerticalStackLayout Spacing="15">
                    
                    <Label Text="Theme Preferences" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource AppTextColor}"/>
                    <Label Text="Customize the look and feel of your dashboard." FontSize="14" TextColor="{DynamicResource AppSubtextColor}"/>
                    
                    <BoxView HeightRequest="1" Color="{DynamicResource AppBorderColor}" Margin="0,5"/>
                    
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Label Text="Mode:" VerticalOptions="Center" TextColor="{DynamicResource AppSubtextColor}" FontSize="14" FontAttributes="Bold" WidthRequest="60"/>
                        <Button Text="Light" Command="{Binding ChangeThemeModeCommand}" CommandParameter="Light" FontSize="14" Padding="15,8" CornerRadius="8" BackgroundColor="{DynamicResource AppBorderColor}" TextColor="{DynamicResource AppTextColor}"/>
                        <Button Text="Dark" Command="{Binding ChangeThemeModeCommand}" CommandParameter="Dark" FontSize="14" Padding="15,8" CornerRadius="8" BackgroundColor="{DynamicResource AppBorderColor}" TextColor="{DynamicResource AppTextColor}"/>
                    </HorizontalStackLayout>
                    
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center" Margin="0,10,0,0">
                        <Label Text="Accent:" VerticalOptions="Center" TextColor="{DynamicResource AppSubtextColor}" FontSize="14" FontAttributes="Bold" WidthRequest="60"/>
                        <!-- Accent Swatches -->
                        <Ellipse WidthRequest="30" HeightRequest="30" Fill="{StaticResource AccentBlue}">
                            <Ellipse.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeAccentColorCommand}" CommandParameter="AccentBlue"/>
                            </Ellipse.GestureRecognizers>
                        </Ellipse>
                        <Ellipse WidthRequest="30" HeightRequest="30" Fill="{StaticResource AccentGreen}">
                            <Ellipse.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeAccentColorCommand}" CommandParameter="AccentGreen"/>
                            </Ellipse.GestureRecognizers>
                        </Ellipse>
                        <Ellipse WidthRequest="30" HeightRequest="30" Fill="{StaticResource AccentPurple}">
                            <Ellipse.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeAccentColorCommand}" CommandParameter="AccentPurple"/>
                            </Ellipse.GestureRecognizers>
                        </Ellipse>
                        <Ellipse WidthRequest="30" HeightRequest="30" Fill="{StaticResource AccentOrange}">
                            <Ellipse.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeAccentColorCommand}" CommandParameter="AccentOrange"/>
                            </Ellipse.GestureRecognizers>
                        </Ellipse>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
