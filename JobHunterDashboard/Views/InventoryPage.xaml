<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JobHunterDashboard.Views.InventoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:domain="clr-namespace:JobHunter.Domain.Models;assembly=JobHunter.Domain"
    xmlns:models="clr-namespace:JobHunterDashboard.Models"
    xmlns:vm="clr-namespace:JobHunterDashboard.ViewModels"
    x:Name="InventoryItemsPage"
    Title="Inventory"
    x:DataType="vm:InventoryViewModel"
    BackgroundColor="{DynamicResource AppBackgroundColor}">

    <Grid RowDefinitions="Auto, Auto, Auto, *">

        <!--  ══════ Header + New Stock Button ══════  -->
        <Grid
            Grid.Row="0"
            Margin="20,10,20,5"
            ColumnDefinitions="*, Auto">
            <HorizontalStackLayout
                Grid.Column="0"
                Spacing="10"
                VerticalOptions="Center">
                <Label
                    FontSize="28"
                    Text="📦"
                    VerticalOptions="Center" />
                <Label
                    FontAttributes="Bold"
                    FontSize="24"
                    Text="Raw Material Inventory"
                    TextColor="{DynamicResource AppTextColor}"
                    VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Button
                Grid.Column="1"
                Padding="14,6"
                BackgroundColor="{DynamicResource AppPrimaryColor}"
                Command="{Binding ShowCreateFormCommand}"
                CornerRadius="8"
                FontAttributes="Bold"
                FontSize="13"
                Text="＋ New Stock"
                TextColor="White"
                VerticalOptions="Center" />
        </Grid>

        <!--  ══════ Filters & Search Bar ══════  -->
        <Border
            Grid.Row="1"
            Margin="20,0,20,10"
            Padding="15,10"
            BackgroundColor="{DynamicResource AppSurfaceColor}"
            Stroke="{DynamicResource AppBorderColor}"
            StrokeShape="RoundRectangle 8"
            StrokeThickness="1">

            <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="15">

                <!--  Search  -->
                <Frame
                    Grid.Column="0"
                    Padding="0"
                    BackgroundColor="Transparent"
                    BorderColor="{DynamicResource AppPrimaryColor}"
                    CornerRadius="8"
                    HasShadow="False"
                    VerticalOptions="Start">
                    <SearchBar
                        Placeholder="Search material, type, or location..."
                        PlaceholderColor="{DynamicResource AppSubtextColor}"
                        Text="{Binding SearchText, Mode=TwoWay}"
                        TextColor="{DynamicResource AppTextColor}" />
                </Frame>

                <!--  Stock Type (Profile Shape) Filter  -->
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Start">
                    <Label
                        Margin="5,0,0,0"
                        FontAttributes="Bold"
                        FontSize="10"
                        Text="Profile:"
                        TextColor="{DynamicResource AppSubtextColor}" />
                    <Border
                        Padding="0"
                        BackgroundColor="Transparent"
                        MinimumWidthRequest="170"
                        Stroke="{DynamicResource AppPrimaryColor}"
                        StrokeShape="RoundRectangle 6"
                        StrokeThickness="1">
                        <VerticalStackLayout>
                            <Button
                                Padding="10,5"
                                BackgroundColor="Transparent"
                                Command="{Binding ToggleTypeDropdownCommand}"
                                FontAttributes="Bold"
                                FontSize="12"
                                HeightRequest="35"
                                Text="Profile Shape ▾"
                                TextColor="{DynamicResource AppPrimaryColor}" />
                            <CollectionView
                                Margin="5,0,5,5"
                                IsVisible="{Binding IsTypeDropdownOpen}"
                                ItemsSource="{Binding StockTypeFilters}"
                                MaximumHeightRequest="350">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:FilterItem">
                                        <HorizontalStackLayout
                                            Margin="0,2"
                                            Spacing="5"
                                            VerticalOptions="Center">
                                            <CheckBox
                                                IsChecked="{Binding IsSelected}"
                                                VerticalOptions="Center"
                                                Color="{DynamicResource AppPrimaryColor}" />
                                            <Label
                                                FontSize="12"
                                                Text="{Binding Name}"
                                                TextColor="{DynamicResource AppTextColor}"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!--  Material Category Filter  -->
                <VerticalStackLayout Grid.Column="2" VerticalOptions="Start">
                    <Label
                        Margin="5,0,0,0"
                        FontAttributes="Bold"
                        FontSize="10"
                        Text="Material:"
                        TextColor="{DynamicResource AppSubtextColor}" />
                    <Border
                        Padding="0"
                        BackgroundColor="Transparent"
                        MinimumWidthRequest="160"
                        Stroke="{DynamicResource AppPrimaryColor}"
                        StrokeShape="RoundRectangle 6"
                        StrokeThickness="1">
                        <VerticalStackLayout>
                            <Button
                                Padding="10,5"
                                BackgroundColor="Transparent"
                                Command="{Binding ToggleMaterialDropdownCommand}"
                                FontAttributes="Bold"
                                FontSize="12"
                                HeightRequest="35"
                                Text="Material ▾"
                                TextColor="{DynamicResource AppPrimaryColor}" />
                            <CollectionView
                                Margin="5,0,5,5"
                                IsVisible="{Binding IsMaterialDropdownOpen}"
                                ItemsSource="{Binding MaterialCategoryFilters}"
                                MaximumHeightRequest="250">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:FilterItem">
                                        <HorizontalStackLayout
                                            Margin="0,2"
                                            Spacing="5"
                                            VerticalOptions="Center">
                                            <CheckBox
                                                IsChecked="{Binding IsSelected}"
                                                VerticalOptions="Center"
                                                Color="{DynamicResource AppPrimaryColor}" />
                                            <Label
                                                FontSize="12"
                                                Text="{Binding Name}"
                                                TextColor="{DynamicResource AppTextColor}"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!--  Sort Picker  -->
                <VerticalStackLayout Grid.Column="3" VerticalOptions="Start">
                    <Label
                        Margin="5,0,0,0"
                        FontAttributes="Bold"
                        FontSize="10"
                        Text="Sort By:"
                        TextColor="{DynamicResource AppSubtextColor}" />
                    <Border
                        Padding="5,0"
                        BackgroundColor="Transparent"
                        MinimumWidthRequest="160"
                        Stroke="{DynamicResource AppPrimaryColor}"
                        StrokeShape="RoundRectangle 6"
                        StrokeThickness="1">
                        <Picker
                            FontAttributes="Bold"
                            FontSize="12"
                            HeightRequest="35"
                            ItemsSource="{Binding SortOptions}"
                            SelectedItem="{Binding SelectedSort}"
                            TextColor="{DynamicResource AppPrimaryColor}" />
                    </Border>
                </VerticalStackLayout>

            </Grid>
        </Border>

        <!--  ══════ Inline Create/Edit Form ══════  -->
        <Border
            Grid.Row="2"
            Margin="20,0,20,10"
            Padding="20"
            BackgroundColor="{DynamicResource AppSurfaceColor}"
            IsVisible="{Binding IsFormVisible}"
            Stroke="{DynamicResource AppPrimaryColor}"
            StrokeShape="RoundRectangle 10"
            StrokeThickness="2">
            <VerticalStackLayout Spacing="12">
                <Label
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="{Binding FormTitle}"
                    TextColor="{DynamicResource AppPrimaryColor}" />

                <!--  Row 1: Type + Material  -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0">
                        <Label
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="Stock Type"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Border
                            Padding="5,0"
                            Stroke="{DynamicResource AppBorderColor}"
                            StrokeShape="RoundRectangle 6"
                            StrokeThickness="1">
                            <Picker
                                HeightRequest="35"
                                ItemDisplayBinding="{Binding Name}"
                                ItemsSource="{Binding StockTypesList}"
                                SelectedItem="{Binding FormStockType}"
                                TextColor="{DynamicResource AppTextColor}" />
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="Material"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Border
                            Padding="5,0"
                            Stroke="{DynamicResource AppBorderColor}"
                            StrokeShape="RoundRectangle 6"
                            StrokeThickness="1">
                            <Picker
                                HeightRequest="35"
                                ItemDisplayBinding="{Binding Name}"
                                ItemsSource="{Binding Materials}"
                                SelectedItem="{Binding FormMaterial}"
                                TextColor="{DynamicResource AppTextColor}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <!--  Row 2: Dimensions  -->
                <Label
                    FontAttributes="Bold"
                    FontSize="11"
                    Text="Dimensions (inches)"
                    TextColor="{DynamicResource AppSubtextColor}" />
                <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0">
                        <Label
                            FontSize="10"
                            Text="OD"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormOD}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label
                            FontSize="10"
                            Text="ID"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormID}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2">
                        <Label
                            FontSize="10"
                            Text="Wall"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormWall}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="3">
                        <Label
                            FontSize="10"
                            Text="Width"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormWidth}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="4">
                        <Label
                            FontSize="10"
                            Text="Height"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormHeight}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="5">
                        <Label
                            FontSize="10"
                            Text="Thickness"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormThickness}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                </Grid>
                <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0">
                        <Label
                            FontSize="10"
                            Text="Length"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormLength}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label
                            FontSize="10"
                            Text="Across Flats"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormAcrossFlats}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2">
                        <Label
                            FontSize="10"
                            Text="Leg Length"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormLegLength}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="3">
                        <Label
                            FontSize="10"
                            Text="Leg Width"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormLegWidth}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="4">
                        <Label
                            FontSize="10"
                            Text="Flange W"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormFlangeWidth}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="5">
                        <Label
                            FontSize="10"
                            Text="Web Depth"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Placeholder="—"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormWebDepth}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                </Grid>

                <!--  Row 3: Quantity + Location  -->
                <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="15">
                    <VerticalStackLayout Grid.Column="0" MinimumWidthRequest="80">
                        <Label
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="Quantity"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Keyboard="Numeric"
                            Text="{Binding FormQuantity}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label
                            FontAttributes="Bold"
                            FontSize="11"
                            Text="Location"
                            TextColor="{DynamicResource AppSubtextColor}" />
                        <Entry
                            BackgroundColor="Transparent"
                            Placeholder="e.g. Rack A-1"
                            PlaceholderColor="{DynamicResource AppBorderColor}"
                            Text="{Binding FormLocation}"
                            TextColor="{DynamicResource AppTextColor}" />
                    </VerticalStackLayout>
                    <Button
                        Grid.Column="2"
                        Margin="0,14,0,0"
                        Padding="18,6"
                        BackgroundColor="{DynamicResource AppPrimaryColor}"
                        Command="{Binding SaveFormCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        FontSize="13"
                        Text="💾 Save"
                        TextColor="White"
                        VerticalOptions="End" />
                    <Button
                        Grid.Column="3"
                        Margin="0,14,0,0"
                        Padding="14,6"
                        BackgroundColor="Transparent"
                        BorderColor="{DynamicResource AppSubtextColor}"
                        BorderWidth="1"
                        Command="{Binding CancelFormCommand}"
                        CornerRadius="8"
                        FontSize="13"
                        Text="Cancel"
                        TextColor="{DynamicResource AppSubtextColor}"
                        VerticalOptions="End" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!--  ══════ Stock Items Grid ══════  -->
        <ContentView Grid.Row="3" Padding="20,0,20,20">
            <CollectionView
                ItemsSource="{Binding StockItems}"
                ItemsUpdatingScrollMode="KeepScrollOffset"
                RemainingItemsThreshold="5"
                RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="domain:StockItem">
                        <!--  Card  -->
                        <Border
                            Margin="0,0,0,10"
                            BackgroundColor="{DynamicResource AppSurfaceColor}"
                            Stroke="{DynamicResource AppBorderColor}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="1">
                            <Border.Shadow>
                                <Shadow
                                    Brush="{DynamicResource AppTextColor}"
                                    Opacity="0.03"
                                    Radius="4"
                                    Offset="0,2" />
                            </Border.Shadow>

                            <Grid
                                Padding="16"
                                ColumnDefinitions="Auto, *, Auto, Auto, Auto"
                                RowDefinitions="Auto, Auto, Auto">

                                <!--  Type badge  -->
                                <Border
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,12,0"
                                    Padding="10,4"
                                    BackgroundColor="{DynamicResource AppPrimaryColor}"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="11"
                                        Text="{Binding StockType.Name}"
                                        TextColor="White" />
                                </Border>

                                <!--  Material name  -->
                                <Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    LineBreakMode="TailTruncation"
                                    Text="{Binding Material.Name}"
                                    TextColor="{DynamicResource AppTextColor}"
                                    VerticalOptions="Center" />

                                <!--  Quantity  -->
                                <HorizontalStackLayout
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="0,0,10,0"
                                    Spacing="4"
                                    VerticalOptions="Center">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="11"
                                        Text="Qty:"
                                        TextColor="{DynamicResource AppSubtextColor}" />
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="14"
                                        Text="{Binding Quantity}"
                                        TextColor="{DynamicResource AppPrimaryColor}" />
                                </HorizontalStackLayout>

                                <!--  Edit Button  -->
                                <Button
                                    Grid.Row="0"
                                    Grid.Column="3"
                                    Margin="0,0,5,0"
                                    Padding="8,4"
                                    BackgroundColor="Transparent"
                                    BorderColor="{DynamicResource AppPrimaryColor}"
                                    BorderWidth="1"
                                    Command="{Binding Source={x:Reference InventoryItemsPage}, Path=BindingContext.EditCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="6"
                                    FontSize="11"
                                    MinimumHeightRequest="30"
                                    MinimumWidthRequest="36"
                                    Text="✏️"
                                    TextColor="{DynamicResource AppPrimaryColor}"
                                    VerticalOptions="Center" />

                                <!--  Delete Button  -->
                                <Button
                                    Grid.Row="0"
                                    Grid.Column="4"
                                    Padding="8,4"
                                    BackgroundColor="Transparent"
                                    BorderColor="#E74C3C"
                                    BorderWidth="1"
                                    Command="{Binding Source={x:Reference InventoryItemsPage}, Path=BindingContext.DeleteCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="6"
                                    FontSize="11"
                                    MinimumHeightRequest="30"
                                    MinimumWidthRequest="36"
                                    Text="🗑️"
                                    TextColor="#E74C3C"
                                    VerticalOptions="Center" />

                                <!--  Dimensions row  -->
                                <HorizontalStackLayout
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="5"
                                    Margin="0,8,0,0"
                                    Spacing="8">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="11"
                                        Text="Dims:"
                                        TextColor="{DynamicResource AppSubtextColor}"
                                        VerticalOptions="Center" />
                                    <Frame
                                        Padding="8,3"
                                        BackgroundColor="{DynamicResource AppBorderColor}"
                                        CornerRadius="10"
                                        HasShadow="False">
                                        <Label
                                            FontSize="11"
                                            Text="{Binding DimensionSummary}"
                                            TextColor="{DynamicResource AppTextColor}" />
                                    </Frame>
                                </HorizontalStackLayout>

                                <!--  Bottom row: Material category + temper + location  -->
                                <HorizontalStackLayout
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="5"
                                    Margin="0,6,0,0"
                                    Spacing="12">
                                    <HorizontalStackLayout Spacing="4">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="10"
                                            Text="Category:"
                                            TextColor="{DynamicResource AppSubtextColor}"
                                            VerticalOptions="Center" />
                                        <Label
                                            FontSize="10"
                                            Text="{Binding Material.Category}"
                                            TextColor="{DynamicResource AppTextColor}"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="10"
                                            Text="Temper:"
                                            TextColor="{DynamicResource AppSubtextColor}"
                                            VerticalOptions="Center" />
                                        <Label
                                            FontSize="10"
                                            Text="{Binding Material.TemperCondition}"
                                            TextColor="{DynamicResource AppTextColor}"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="10"
                                            Text="📍"
                                            TextColor="{DynamicResource AppSubtextColor}"
                                            VerticalOptions="Center" />
                                        <Label
                                            FontSize="10"
                                            Text="{Binding Location}"
                                            TextColor="{DynamicResource AppTextColor}"
                                            VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ContentView>

    </Grid>
</ContentPage>
